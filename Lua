local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer

local AutoSell = false
local AutoFire = false
local AutoWater = false
local Noclip = false

local sellContainer = workspace.World.Stats.Sell:GetChildren()[4]
local SellPart = nil
if sellContainer then
    local part = sellContainer:FindFirstChild("part")
    if part then
        SellPart = part:FindFirstChildOfClass("TouchInterest") or part
    end
end

local FirePart = workspace.World.Stats.FireElement.FireEl.part
local WaterPart = workspace.World.Stats.WaterElement.WaterEl.part

local function getChar()
    return LP.Character or LP.CharacterAdded:Wait()
end

local function getHRP()
    return getChar():FindFirstChild("HumanoidRootPart")
end

RunService.Stepped:Connect(function()
    if Noclip then
        local char = getChar()
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                v.CanCollide = false
            end
        end
    end
end)

local MainTab = Window:CreateTab("Main")
local ElementsTab = Window:CreateTab("Elements")

MainTab:CreateToggle({
    Name = "Auto Sell (8x)",
    CurrentValue = false,
    Callback = function(Value)
        AutoSell = Value
        if Value then
            task.spawn(function()
                while AutoSell do
                    local hrp = getHRP()
                    if hrp and SellPart then
                        for _ = 1, 8 do
                            firetouchinterest(hrp, SellPart, 0)
                            firetouchinterest(hrp, SellPart, 1)
                            task.wait(0.02)
                        end
                    end
                    task.wait()
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Noclip (Important)",
    CurrentValue = false,
    Callback = function(Value)
        Noclip = Value
    end
})

ElementsTab:CreateToggle({
    Name = "Auto Fire",
    CurrentValue = false,
    Callback = function(Value)
        AutoFire = Value
        if Value then
            task.spawn(function()
                while AutoFire do
                    local hrp = getHRP()
                    if hrp and FirePart then
                        firetouchinterest(hrp, FirePart, 0)
                        firetouchinterest(hrp, FirePart, 1)
                    end
                    task.wait()
                end
            end)
        end
    end
})

ElementsTab:CreateToggle({
    Name = "Auto Water",
    CurrentValue = false,
    Callback = function(Value)
        AutoWater = Value
        if Value then
            task.spawn(function()
                while AutoWater do
                    local hrp = getHRP()
                    if hrp and WaterPart then
                        firetouchinterest(hrp, WaterPart, 0)
                        firetouchinterest(hrp, WaterPart, 1)
                    end
                    task.wait()
                end
            end)
        end
    end
})
