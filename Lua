local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LP = Players.LocalPlayer

local AutoSell = false
local AutoFire = false
local AutoWater = false
local Noclip = false

local SellPart = workspace.World.Stats.Sell.MoneySell.part
local FirePart = workspace.World.Stats.FireElement.FireEl.part
local WaterPart = workspace.World.Stats.WaterElement.WaterEl.part

local function getChar()
    return LP.Character or LP.CharacterAdded:Wait()
end

local function getHRP()
    return getChar():FindFirstChild("HumanoidRootPart")
end

local function touch(part)
    local hrp = getHRP()
    if hrp and part then
        firetouchinterest(hrp, part, 0)
        firetouchinterest(hrp, part, 1)
    end
end

-- Noclip loop
RunService.Stepped:Connect(function()
    if Noclip then
        local char = getChar()
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                v.CanCollide = false
            end
        end
    end
end)

local MainTab = Window:CreateTab("Main")

MainTab:CreateToggle({
    Name = "Auto Sell",
    CurrentValue = false,
    Callback = function(Value)
        AutoSell = Value
        if Value then
            task.spawn(function()
                while AutoSell do
                    pcall(function()
                        touch(SellPart)
                    end)
                    task.wait()
                end
            end)
        end
    end
})

-- ✅ Noclip toggle added here
MainTab:CreateToggle({
    Name = "Noclip (Important)",
    CurrentValue = false,
    Callback = function(Value)
        Noclip = Value
    end
})

