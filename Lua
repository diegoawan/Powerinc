local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local AutoSell = false
local AutoFire = false
local AutoWater = false

local SellPart = workspace.World.Stats.Sell.MoneySell.part
local FirePart = workspace.World.Stats.FireElement.FireEl.part
local WaterPart = workspace.World.Stats.WaterElement.WaterEl.part

local function getHRP()
    local char = LP.Character or LP.CharacterAdded:Wait()
    return char:FindFirstChild("HumanoidRootPart")
end

local function safeTouch(part)
    local hrp = getHRP()
    if not hrp or not part then return end

    local oldCFrame = hrp.CFrame
    hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    task.wait()
    firetouchinterest(hrp, part, 0)
    firetouchinterest(hrp, part, 1)
    task.wait()
    hrp.CFrame = oldCFrame
end

local MainTab = Window:CreateTab("Main")

MainTab:CreateToggle({
    Name = "Auto Sell",
    CurrentValue = false,
    Callback = function(Value)
        AutoSell = Value
        if Value then
            task.spawn(function()
                while AutoSell do
                    pcall(function()
                        safeTouch(SellPart)
                    end)
                    task.wait(0.2)
                end
            end)
        end
    end
})

